{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "GoToken API 文档",
  "description": "gogogotoken.com — 国内站 Seedance / Seedream API 使用指南",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "logo": {
    "light": "/logo/gogogotoken-logo-light.png",
    "dark": "/logo/gogogotoken-logo-dark.png",
    "href": "https://gogogotoken.com"
  },
  "favicon": "/favicon.png",
  "redirects": [
    {
      "source": "/gogogotokenzh/:slug*",
      "destination": "/introduction"
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "返回控制台",
        "href": "https://gogogotoken.com"
      }
    ]
  },
  "footer": {
    "socials": {}
  },
  "icons": {
    "library": "lucide"
  },
  "api": {
    "mdx": {
      "server": "https://gogogotoken.com",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "开始使用",
        "public": true,
        "icon": "rocket",
        "pages": [
          "introduction",
          "auth"
        ]
      },
      {
        "group": "图片生成",
        "public": true,
        "icon": "image",
        "pages": [
          "images"
        ]
      },
      {
        "group": "Seedance 视频",
        "public": true,
        "icon": "video",
        "pages": [
          "video-models",
          "video-generations",
          "video-tasks",
          "video-tools",
          "seedance-token"
        ]
      },
      {
        "group": "Seedance 素材",
        "public": true,
        "icon": "folder-kanban",
        "pages": [
          "assets"
        ]
      },
      {
        "group": "兼容接口",
        "public": true,
        "icon": "plug",
        "pages": [
          "openai-compatible",
          "kling-compatible",
          "jimeng-compatible"
        ]
      },
      {
        "group": "账户与计费",
        "public": true,
        "icon": "wallet",
        "pages": [
          "billing"
        ]
      }
    ]
  }
}
